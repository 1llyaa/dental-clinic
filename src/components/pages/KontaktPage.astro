---
import Base from '../../layouts/Base.astro';
import { getTranslations, type Locale } from '../../i18n/utils';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = getTranslations(locale);
const k = t.kontakt;
---
<Base title={k.meta.title} description={k.meta.description}>

  <section class="page-header">
    <div class="wrap">
      <h1>{k.header.h1}</h1>
      <p>{k.header.sub}</p>
    </div>
  </section>

  <section class="contact-main">
    <div class="wrap">
      <div class="contact-grid">
        <div class="contact-block fade-in">
          <h2>{k.contact.phoneHeading}</h2>
          <a href={t.site.phoneLink} class="contact-phone-big">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            {t.site.phone}
          </a>
          <h2>{k.contact.hoursHeading}</h2>
          <table class="hours-table">
            {k.contact.hours.map(row => (
              <tr>
                <td>{row.day}</td>
                <td style={row.closed ? 'color:var(--text-muted);font-weight:400;' : ''}>{row.time}</td>
              </tr>
            ))}
          </table>
          <h2>{k.contact.addressHeading}</h2>
          <div class="address-block">
            <p><strong>{k.contact.addressLine1}</strong></p>
            <p>{k.contact.addressLine2}</p>
            <p class="address-note">{k.contact.addressNote}</p>
          </div>
        </div>
        <div class="fade-in" style="animation-delay:0.15s">
          <div class="map-placeholder">{k.contact.mapAlt}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="new-patients">
    <div class="wrap fade-in">
      <h2>{k.newPatients.h2}</h2>
      {k.newPatients.paragraphs.map(p => <p>{p}</p>)}
      <a href={t.site.phoneLink} class="new-patients-cta">
        {k.newPatients.cta}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
        </svg>
      </a>
    </div>
  </section>

  <section class="emergency">
    <div class="wrap fade-in">
      <div class="emergency-inner">
        <h2>{k.emergency.h2}</h2>
        <p>{k.emergency.intro}</p>
        <p><strong>{k.emergency.name}</strong></p>
        <p>{k.emergency.address}</p>
        <p>{k.emergency.addressNote}</p>
        <p><a href={`https://${k.emergency.url}`} target="_blank" rel="noopener">{k.emergency.url}</a></p>
        <div class="emergency-hours">
          <strong>{k.emergency.hoursHeading}</strong><br />
          {k.emergency.hours1}<br />
          {k.emergency.hours2}
        </div>
      </div>
    </div>
  </section>

  <section class="legal-id">
    <div class="wrap fade-in">
      <h2>{k.legalId.h2}</h2>
      <p set:html={k.legalId.text.replace(/\n/g, '<br />')} />
    </div>
  </section>

  <section class="cta-block">
    <div class="wrap">
      <h2>{k.cta.title}</h2>
      <p class="cta-sub">{k.cta.sub}</p>
      <a href={t.site.phoneLink} class="cta-phone">{t.site.phone}</a>
      <div class="cta-hours">{k.cta.hours}</div>
    </div>
  </section>

</Base>

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) { entry.target.classList.add('visible'); observer.unobserve(entry.target); }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
